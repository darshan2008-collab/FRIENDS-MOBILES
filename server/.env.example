# Environment & Server Port
PORT=5000
DATABASE_URL=postgres://postgres:postgres@localhost:5432/friends_mobile
NODE_ENV=development

# Production & Docker SMTP Email Settings (For OTP & Password Reset)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
FROM_EMAIL="FRIENDS MOBILE Security" <support@friendsmobile.in>

GMAIL_USER=your_email@gmail.com
GMAIL_APP_PASSWORD=your_app_password

# Live Deployment URLs
PUBLIC_APP_URL=https://friends-mobiles-bb9x-eight.vercel.app
VITE_API_BASE_URL=https://friends-mobiles-bb9x-eight.vercel.app/api

# Google OAuth Authentication Keys
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
VITE_GOOGLE_CLIENT_ID=your_google_client_id

# Automated GitHub Database Backup Frequency (In Hours)
BACKUP_INTERVAL_HOURS=1
